---
import clinic from '../data/clinic.json';
import Icon from './Icon.astro';

const features = clinic.features_list || [];
---

<section class="py-20 px-4 bg-slate-50">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Why Choose Us</h2>
      <div class="w-24 h-1 bg-blue-600 mx-auto rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="flex flex-col items-center text-center p-8 bg-white border border-slate-100 rounded-3xl shadow-sm hover:shadow-lg transition-all duration-300">
          <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mb-6">
            <Icon name={feature.title} className="w-8 h-8" />
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">{feature.title}</h3>
          <p class="text-slate-600 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
