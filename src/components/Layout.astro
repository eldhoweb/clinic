---
import '../styles/global.css';
import clinic from '../data/clinic.json';

const theme = {
  primary:    (clinic.theme as any)?.primary    ?? '#0ea5e9',
  secondary:  (clinic.theme as any)?.secondary  ?? '#38bdf8',
  background: (clinic.theme as any)?.background ?? '#f8fafc',
  text:       (clinic.theme as any)?.text       ?? '#0f172a',
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={clinic.description || clinic.tagline} />
    <title>{clinic.clinic_name}</title>

    <!-- Dynamic theme variables from clinic.json -->
    <style set:html={`
      :root {
        --color-primary:    ${theme.primary};
        --color-secondary:  ${theme.secondary};
        --color-bg:         ${theme.background};
        --color-text:       ${theme.text};
      }
      ::selection {
        background: var(--color-primary);
        color: #fff;
      }
      html {
        scroll-behavior: smooth;
      }
    `}></style>
  </head>

  <body style={`background-color:${theme.background}; color:${theme.text};`}
        class="font-sans antialiased flex flex-col min-h-screen">

    <main class="flex-grow">
      <slot />
    </main>

    <!-- Premium minimal footer: text-color bg, bg-color text -->
    <footer style={`background-color:${theme.text}; color:${theme.background};`}
            class="py-10 reveal">
      <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm opacity-90">
        <p>&copy; {new Date().getFullYear()} <strong>{clinic.clinic_name}</strong>. All rights reserved.</p>
        <p>
          Designed by{' '}
          <a
            href="https://eldhoweb.com"
            target="_blank"
            rel="noopener noreferrer"
            style={`color:${theme.secondary};`}
            class="font-semibold hover:opacity-80 transition-opacity"
          >EldhoWeb</a>
        </p>
      </div>
    </footer>

    <script>
      document.addEventListener('DOMContentLoaded', () => {

        /* ── Reveal / card scroll animations ── */
        const revealObs = new IntersectionObserver((entries, obs) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              obs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12 });

        document.querySelectorAll('.reveal, .card').forEach(el => revealObs.observe(el));

        /* ── Count-up for [data-target] elements ── */
        const countObs = new IntersectionObserver((entries, obs) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            const target = parseFloat(el.dataset.target ?? '0');
            const isDecimal = !Number.isInteger(target);
            const duration = 1800;
            const start = performance.now();

            const tick = (now: number) => {
              const p = Math.min((now - start) / duration, 1);
              const ease = p * (2 - p);          // ease-out quad
              const val = target * ease;
              el.textContent = isDecimal ? val.toFixed(1) : String(Math.floor(val));
              if (p < 1) requestAnimationFrame(tick);
              else el.textContent = String(target);
            };
            requestAnimationFrame(tick);
            obs.unobserve(el);
          });
        }, { threshold: 0.2 });

        document.querySelectorAll('[data-target]').forEach(el => countObs.observe(el));

        /* ── Hero tagline typing effect ── */
        const tagline = document.querySelector<HTMLElement>('.hero-tagline');
        if (tagline) {
          const text = tagline.dataset.text ?? tagline.textContent ?? '';
          tagline.textContent = '';
          let i = 0;
          setTimeout(() => {
            const timer = setInterval(() => {
              tagline.textContent += text[i++];
              if (i >= text.length) {
                clearInterval(timer);
                tagline.classList.add('typed');
              }
            }, 48);
          }, 500);
        }
      });
    </script>
  </body>
</html>
