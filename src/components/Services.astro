---
import clinic from '../data/clinic.json';

const theme = {
  primary:    (clinic.theme as any)?.primary    ?? '#0ea5e9',
  secondary:  (clinic.theme as any)?.secondary  ?? '#38bdf8',
  background: (clinic.theme as any)?.background ?? '#f8fafc',
  text:       (clinic.theme as any)?.text       ?? '#0f172a',
};

const services = (clinic.services as any[]) || [];

const getIcon = (name: string): string => {
  const n = name.toLowerCase();
  if (n.includes('whiten') || n.includes('cosmetic'))
    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`;
  if (n.includes('general') || n.includes('check') || n.includes('routine'))
    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`;
  if (n.includes('implant'))
    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="12" cy="5" r="3"/><line x1="12" y1="8" x2="12" y2="21"/><line x1="8" y1="15" x2="16" y2="15"/></svg>`;
  if (n.includes('root') || n.includes('canal'))
    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M9 3H5a2 2 0 0 0-2 2v4"/><path d="M19 3h-4"/><path d="M2 12h5"/><path d="M2 19l4-4"/><path d="M15 3v18"/><path d="M19 3v4a2 2 0 0 1-2 2h-2"/></svg>`;
  if (n.includes('ortho') || n.includes('brace') || n.includes('align'))
    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/><circle cx="8"  cy="6"  r="1.5" fill="currentColor"/><circle cx="16" cy="12" r="1.5" fill="currentColor"/><circle cx="12" cy="18" r="1.5" fill="currentColor"/></svg>`;
  // default dental icon
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M12 2C8 2 5 5 5 8c0 2 1 3.5 1.5 5C7 15.5 7 18 8 20c.5 1 1.5 2 4 2s3.5-1 4-2c1-2 1-4.5 1.5-7 .5-1.5 1.5-3 1.5-5 0-3-3-6-7-6z"/></svg>`;
};
---

<section id="services" class="py-24 px-6 reveal" style={`background:${theme.background};`}>
  <div class="max-w-6xl mx-auto">

    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <p class="text-sm font-semibold uppercase tracking-widest mb-3" style={`color:${theme.primary};`}>
        What We Offer
      </p>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight mb-4" style={`color:${theme.text};`}>
        Our Services
      </h2>
      <p class="max-w-xl mx-auto text-base leading-relaxed" style={`color:${theme.text}80;`}>
        Comprehensive dental care delivered with modern technology and a gentle touch.
      </p>
    </div>

    <!-- 3-column grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service: {name: string; description: string}) => (
        <div
          class="service-card card group flex flex-col gap-5 p-8 rounded-2xl border bg-white cursor-pointer"
          style={`border-color:${theme.primary}20;`}
        >
          <!-- Icon bubble -->
          <div
            class="w-13 h-13 w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
            style={`background:${theme.primary}12; color:${theme.primary};`}
          >
            <div set:html={getIcon(service.name)} />
          </div>

          <div>
            <h3 class="text-lg font-bold mb-2" style={`color:${theme.text};`}>{service.name}</h3>
            <p class="text-sm leading-relaxed" style={`color:${theme.text}75;`}>{service.description}</p>
          </div>

          <!-- Subtle arrow on hover -->
          <span
            class="mt-auto text-sm font-semibold flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            style={`color:${theme.primary};`}
          >
            Learn more
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
            </svg>
          </span>
        </div>
      ))}
    </div>

  </div>
</section>