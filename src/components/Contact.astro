---
import clinic from '../data/clinic.json';

const theme = {
  primary:    (clinic.theme as any)?.primary    ?? '#0ea5e9',
  secondary:  (clinic.theme as any)?.secondary  ?? '#38bdf8',
  background: (clinic.theme as any)?.background ?? '#f8fafc',
  text:       (clinic.theme as any)?.text       ?? '#0f172a',
};

const msg          = clinic.whatsapp_message ? `?text=${encodeURIComponent(clinic.whatsapp_message)}` : '';
const whatsappLink = clinic.whatsapp
  ? `https://wa.me/${clinic.whatsapp.replace(/\D/g, '')}${msg}`
  : null;
const phoneLink    = clinic.phone ? `tel:${clinic.phone.replace(/\D/g, '')}` : null;
const mapUrl       = (clinic as any).google_maps_link
  ?? `https://www.google.com/maps?q=${encodeURIComponent(`${clinic.clinic_name}, ${clinic.location}`)}&output=embed`;
---

<section
  class="py-24 px-6 reveal"
  style={`background:${theme.background}; border-top:1px solid ${theme.primary}15;`}
>
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="mb-16 reveal">
      <p class="text-sm font-semibold uppercase tracking-widest mb-2" style={`color:${theme.primary};`}>
        Find Us
      </p>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight" style={`color:${theme.text};`}>
        Get In Touch
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left: info + buttons -->
      <div class="flex flex-col gap-8 reveal">

        <p class="text-lg leading-relaxed" style={`color:${theme.text}80;`}>
          We're dedicated to giving you the best dental care. Reach out to book an appointment or ask a question.
        </p>

        <!-- Location -->
        {clinic.location && (
          <div class="flex items-start gap-4 group">
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 transition-colors duration-200"
              style={`background:${theme.primary}12; color:${theme.primary};`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                <path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider font-semibold mb-1" style={`color:${theme.primary};`}>Location</p>
              <p class="font-medium" style={`color:${theme.text};`}>{clinic.location}</p>
            </div>
          </div>
        )}

        <!-- Phone -->
        {clinic.phone && (
          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
              style={`background:${theme.primary}12; color:${theme.primary};`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.13 12 19.79 19.79 0 0 1 1 3.18 2 2 0 0 1 3 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91A16 16 0 0 0 14 15.91l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider font-semibold mb-1" style={`color:${theme.primary};`}>Phone</p>
              <p class="font-medium" style={`color:${theme.text};`}>{clinic.phone}</p>
            </div>
          </div>
        )}

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          {whatsappLink && (
            <a
              href={whatsappLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-full font-bold text-sm shadow-md hover:shadow-lg hover:scale-105 active:scale-95 transition-all duration-200"
              style="background:#25D366; color:#fff;"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
              </svg>
              WhatsApp Us
            </a>
          )}
          {phoneLink && (
            <a
              href={phoneLink}
              class="inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-full font-bold text-sm border hover:scale-105 active:scale-95 transition-all duration-200"
              style={`border-color:${theme.primary}50; color:${theme.primary}; background:transparent;`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.13 12 19.79 19.79 0 0 1 1 3.18 2 2 0 0 1 3 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91A16 16 0 0 0 14 15.91l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              Call Now
            </a>
          )}
        </div>

      </div>

      <!-- Right: map -->
      <div
        class="reveal w-full h-[420px] rounded-2xl overflow-hidden shadow-xl"
        style={`border:1px solid ${theme.primary}20;`}
      >
        <iframe
          src={mapUrl}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>

    </div>
  </div>
</section>