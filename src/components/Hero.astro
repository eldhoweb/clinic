---
import clinic from '../data/clinic.json';

const theme = {
  primary:    (clinic.theme as any)?.primary    ?? '#0ea5e9',
  secondary:  (clinic.theme as any)?.secondary  ?? '#38bdf8',
  background: (clinic.theme as any)?.background ?? '#f8fafc',
  text:       (clinic.theme as any)?.text       ?? '#0f172a',
};

const rawNumber  = (clinic as any).whatsapp_business_number || clinic.whatsapp;
const msgParam   = clinic.whatsapp_message
                   ? `?text=${encodeURIComponent(clinic.whatsapp_message)}`
                   : '';
const whatsappLink = rawNumber
  ? `https://wa.me/${rawNumber.replace(/\D/g, '')}${msgParam}`
  : null;

const showRating  = (clinic as any).google_rating;
const showReviews = (clinic as any).review_count;
const showTrust   = showRating || showReviews;
---

<!-- Hero: bg uses JSON background + subtle mesh, headings from JSON text/primary -->
<section
  class="hero-mesh flex items-center justify-center min-h-[90vh] px-6 py-24 text-center reveal"
  style={`background-color:${theme.background};`}
>
  <div class="max-w-4xl mx-auto flex flex-col items-center gap-8">

    <!-- Eyebrow label -->
    <span
      class="inline-block text-xs font-semibold tracking-widest uppercase px-4 py-1.5 rounded-full border"
      style={`color:${theme.primary}; border-color:${theme.primary}33;`}
    >
      Trusted Dental Care
    </span>

    <!-- Main heading -->
    <h1
      class="text-5xl md:text-7xl font-black leading-[1.05] tracking-tight"
      style={`color:${theme.text};`}
    >
      {clinic.clinic_name}
    </h1>

    <!-- Animated tagline -->
    <p
      class="hero-tagline max-w-2xl text-xl md:text-2xl font-medium leading-relaxed min-h-[3rem]"
      style={`color:${theme.text}99;`}
      data-text={clinic.tagline}
    >{clinic.tagline}</p>

    <!-- CTA row -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 w-full">
      {whatsappLink && (
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-3 px-9 py-4 rounded-full text-base font-bold shadow-lg hover:shadow-xl hover:scale-105 active:scale-95 transition-all duration-200"
          style={`background:${theme.primary}; color:#fff;`}
        >
          <!-- WhatsApp icon -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 shrink-0">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
          </svg>
          Book on WhatsApp
        </a>
      )}

      {(clinic.services as any)?.length > 0 && (
        <a
          href="#services"
          class="w-full sm:w-auto inline-flex items-center justify-center px-9 py-4 rounded-full text-base font-bold border hover:scale-105 active:scale-95 transition-all duration-200"
          style={`color:${theme.primary}; border-color:${theme.primary}40; background:transparent;`}
        >
          View Services
        </a>
      )}
    </div>

    <!-- Glassmorphism trust badge -->
    {showTrust && (
      <div
        class="glass-badge inline-flex items-center gap-3 px-6 py-2.5 rounded-full text-sm font-medium"
        style={`color:${theme.text};`}
      >
        {showRating && (
          <span class="flex items-center gap-1.5">
            <span class="text-amber-400">★</span>
            <span data-target={(clinic as any).google_rating}>{(clinic as any).google_rating}</span>
            <span style={`color:${theme.text}60;`}>Google Rating</span>
          </span>
        )}
        {showRating && showReviews && (
          <span class="w-px h-4 rounded-full" style={`background:${theme.text}20;`}></span>
        )}
        {showReviews && (
          <span class="flex items-center gap-1">
            <span data-target={(clinic as any).review_count}>{(clinic as any).review_count}</span>
            <span style={`color:${theme.text}60;`}>+ Reviews</span>
          </span>
        )}
      </div>
    )}

  </div>
</section>